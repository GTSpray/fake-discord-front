{
  "$schema": "../schema/scenario.schema.json",
  "id": "poll-moderator-flow",
  "title": "Création d'un sondage (modérateur)",
  "doc": "docs/usage/poll/poll.md",
  "chrome": {
    "guild": {
      "name": "Serveur de démo"
    },
    "channel": {
      "name": "général",
      "type": "text"
    },
    "membersOnline": 12,
    "viewer": {
      "name": "Modo",
      "status": "Online"
    }
  },
  "actions": [
    {
      "type": "wait",
      "ms": 1500
    },
    {
      "type": "focusInput"
    },
    {
      "type": "wait",
      "ms": 1200
    },
    {
      "type": "type",
      "text": "/poll",
      "msPerChar": 80
    },
    {
      "type": "type",
      "text": " create",
      "msPerChar": 70,
      "revealSuggestions": {
        "after": "/poll ",
        "suggestions": [
          {
            "name": "create",
            "description": "créer un sondage"
          }
        ]
      }
    },
    {
      "type": "wait",
      "ms": 800
    },
    {
      "type": "pressEnter"
    },
    {
      "type": "openModal",
      "modal": {
        "type": 9,
        "data": {
          "title": "Créer un sondage",
          "components": [
            {
              "type": 18,
              "label": "Titre du sondage",
              "component": {
                "type": 4,
                "custom_id": "title",
                "style": 1,
                "required": true
              }
            },
            {
              "type": 18,
              "label": "Role des sondés",
              "component": {
                "type": 6,
                "custom_id": "role",
                "required": false
              }
            },
            {
              "type": 18,
              "label": "Question du sondage",
              "component": {
                "type": 4,
                "custom_id": "question",
                "style": 1,
                "required": true
              }
            },
            {
              "type": 18,
              "label": "Description",
              "component": {
                "type": 4,
                "custom_id": "description",
                "style": 1,
                "required": false
              }
            }
          ]
        }
      }
    },
    {
      "type": "fillModal",
      "values": {
        "title": "Repas de fin d'année",
        "question": "Quel jour ?",
        "description": "Votez pour la date qui vous arrange"
      },
      "msPerField": 130
    },
    {
      "type": "wait",
      "ms": 700
    },
    {
      "type": "submitModal"
    },
    {
      "type": "showEphemeral",
      "ephemeral": {
        "slashInvocation": {
          "user": {
            "name": "Modo",
            "color": "#5865f2"
          },
          "command": "poll create"
        },
        "type": 4,
        "data": {
          "flags": 64,
          "content": "## Repas de fin d'année\n\n1. Quel jour ?\n    - Vendredi\n    - Samedi",
          "components": [
            {
              "type": 1,
              "components": [
                {
                  "type": 2,
                  "style": 1,
                  "label": "Ajouter des choix"
                },
                {
                  "type": 2,
                  "style": 1,
                  "label": "Nouvelle question"
                },
                {
                  "type": 2,
                  "style": 1,
                  "label": "Publier le sondage"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "wait",
      "ms": 1400
    },
    {
      "type": "clickButton",
      "label": "Publier le sondage"
    },
    {
      "type": "applyState",
      "layers": {
        "messages": [
          {
            "author": {
              "name": "Bot",
              "bot": true
            },
            "timestamp": "16/06/2026 12:17",
            "deletedReply": true,
            "interaction": {
              "type": 4,
              "data": {
                "flags": 32768,
                "components": [
                  {
                    "type": 9,
                    "components": [
                      {
                        "type": 10,
                        "content": "# Oyé Oyé !\n-# Le staff réclame votre attention pour un sondage!"
                      },
                      {
                        "type": 10,
                        "content": "Je vais mettre un titre long pour vérifier"
                      }
                    ],
                    "accessory": {
                      "type": 11,
                      "media": {
                        "url": "https://placehold.co/80x80/png"
                      }
                    }
                  },
                  {
                    "type": 14,
                    "divider": true,
                    "spacing": 1
                  },
                  {
                    "type": 1,
                    "components": [
                      {
                        "type": 2,
                        "style": 1,
                        "label": "Je vote!"
                      },
                      {
                        "type": 2,
                        "style": 2,
                        "label": "Compte rendu"
                      }
                    ]
                  }
                ]
              }
            }
          }
        ]
      },
      "holdMs": 2000
    }
  ],
  "output": {
    "directory": "output/poll",
    "prefix": "poll-moderator-animated",
    "video": true
  }
}
