{
  "$schema": "../schema/scenario.schema.json",
  "id": "poll-moderator-flow",
  "title": "Poll — créer, choix, nouvelle question, publier",
  "doc": "docs/usage/poll/poll.md",
  "chrome": {
    "guild": {
      "name": "Serveur de démo"
    },
    "channel": {
      "name": "général",
      "type": "text"
    },
    "membersOnline": 12,
    "viewer": {
      "name": "Modo",
      "status": "Online"
    }
  },
  "defaults": {
    "botPendingText": "Envoi de la commande..."
  },
  "actions": [
    {
      "type": "wait",
      "ms": 1500
    },
    {
      "type": "focusInput"
    },
    {
      "type": "applyState",
      "layers": {
        "messages": [
          {
            "author": {
              "name": "P'tit Pote",
              "bot": true,
              "avatarUrl": "https://raw.githubusercontent.com/GTSpray/P-titPote/main/assets/ptitpote.png"
            },
            "ephemeral": true,
            "interaction": {
              "type": 4,
              "data": {
                "flags": 64,
                "content": "## Repas de fin d'année\n\n1. Quel jour ?\n    - mercredi\n    - jeudi\n    - vendredi\n2. avez vous des alergenes",
                "components": [
                  {
                    "type": 1,
                    "components": [
                      {
                        "type": 2,
                        "style": 1,
                        "label": "Ajouter des choix"
                      },
                      {
                        "type": 2,
                        "style": 1,
                        "label": "Nouvelle question"
                      },
                      {
                        "type": 2,
                        "style": 1,
                        "label": "Publier le sondage"
                      }
                    ]
                  }
                ]
              }
            }
          }
        ]
      }
    },
    {
      "type": "wait",
      "ms": 1600
    },
    {
      "type": "clickButton",
      "label": "Publier le sondage"
    },
    {
      "type": "applyState",
      "layers": {
        "messages": [
          {
            "author": {
              "name": "P'tit Pote",
              "bot": true,
              "avatarUrl": "https://raw.githubusercontent.com/GTSpray/P-titPote/main/assets/ptitpote.png"
            },
            "timestamp": "15:10",
            "deletedReply": true,
            "interaction": {
              "type": 4,
              "data": {
                "flags": 32768,
                "components": [
                  {
                    "type": 9,
                    "components": [
                      {
                        "type": 10,
                        "content": "# Oyé Oyé !\n-# Le staff réclame votre attention pour un sondage!"
                      },
                      {
                        "type": 10,
                        "content": "Repas de fin d'année"
                      }
                    ],
                    "accessory": {
                      "type": 11,
                      "media": {
                        "url": "https://raw.githubusercontent.com/GTSpray/P-titPote/main/assets/ptitpote-sam.png"
                      }
                    }
                  },
                  {
                    "type": 14,
                    "divider": true,
                    "spacing": 1
                  },
                  {
                    "type": 1,
                    "components": [
                      {
                        "type": 2,
                        "style": 1,
                        "label": "Je vote!"
                      },
                      {
                        "type": 2,
                        "style": 2,
                        "label": "Compte rendu"
                      }
                    ]
                  }
                ]
              }
            }
          },
          {
            "author": {
              "name": "P'tit Pote",
              "bot": true,
              "avatarUrl": "https://raw.githubusercontent.com/GTSpray/P-titPote/main/assets/ptitpote.png"
            },
            "ephemeral": true,
            "interaction": {
              "type": 4,
              "data": {
                "flags": 64,
                "content": "Sondage publié !"
              }
            }
          }
        ]
      },
      "holdMs": 3000
    }
  ],
  "output": {
    "directory": "docs/usage/poll",
    "prefix": "poll-moderator-flow",
    "video": true
  }
