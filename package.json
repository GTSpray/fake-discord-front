{
  "name": "ptitpote-doc-studio",
  "private": true,
  "version": "0.1.0",
  "description": "Discord-like playback renderer for documentation captures",
  "type": "module",
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "validate": "node scripts/validate-scenario.mjs",
    "capture": "node scripts/capture.mjs",
    "snapshots": "node scripts/capture-snapshots.mjs",
    "snapshots:check": "node scripts/capture-snapshots.mjs --check-only",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@skyra/discord-components-core": "^4.0.2",
    "@skyra/discord-components-react": "^4.0.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-type-animation": "^3.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.52.0",
    "prettier": "^3.9.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.10"
  },
  "license": "MIT"
}
